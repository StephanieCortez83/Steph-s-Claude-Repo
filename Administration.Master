<%@ Master Language="C#" MasterPageFile="~/ClinicalCodingSolutions.Master" AutoEventWireup="true"
  CodeBehind="Administration.master.cs" Inherits="CCSWeb.WebPages.Administration" %>

<%@ MasterType VirtualPath="~/ClinicalCodingSolutions.Master" %>
<asp:Content ID="Content2" ContentPlaceHolderID="ScriptsAndCSS" runat="server">
  <asp:ContentPlaceHolder ID="ScriptsAndCSS" runat="server">
  </asp:ContentPlaceHolder>
</asp:Content>
<asp:Content ID="Content3" ContentPlaceHolderID="PageBody" runat="server">
<div class="IntroArea">
  <asp:ContentPlaceHolder ID="IntroArea" runat="server"></asp:ContentPlaceHolder>
</div>
<div class="MainBodyArea">
  <div class="main">
    <!-- Errors -->
    <cc1:ErrorListView ID="ErrorListView1" runat="server"></cc1:ErrorListView>
    <!-- Page Content -->
    <asp:ContentPlaceHolder ID="MainContent" runat="server"></asp:ContentPlaceHolder>
  </div>
</div>
</asp:Content>
<asp:Content ID="Content1" ContentPlaceHolderID="Scripts" runat="server">
  <asp:ContentPlaceHolder ID="Scripts" runat="server">
  </asp:ContentPlaceHolder>
</asp:Content>
